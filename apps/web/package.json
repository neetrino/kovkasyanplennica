{
  "name": "@shop/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ../../node_modules/next/dist/bin/next dev",
    "dev:webpack": "node ../../node_modules/next/dist/bin/next dev --no-turbo",
    "dev:clean": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\" && node ../../node_modules/next/dist/bin/next dev",
    "prebuild": "node scripts/ensure-prisma-generate.js",
    "prebuild:migrate": "node scripts/run-migrations.js",
    "build": "node ../../node_modules/next/dist/bin/next build --experimental-build-mode=compile",
    "start": "node ../../node_modules/next/dist/bin/next start",
    "lint": "eslint .",
    "upload:r2-assets": "tsx scripts/upload-public-assets-to-r2.ts",
    "optimize:home-images": "tsx scripts/optimize-homepage-images.ts --from-api https://kovkasyanplennica.vercel.app",
    "optimize:catalog-images": "tsx scripts/optimize-catalog-images.ts --upload",
    "clean": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\"",
    "prisma:generate": "cd ../../packages/db && npm run db:generate",
    "reset": "node -e \"require('fs').rmSync('.next', {recursive: true, force: true})\" && cd ../../packages/db && npm run db:generate",
    "redis:up": "docker compose -f ../../docker-compose.yml up -d redis",
    "redis:down": "docker compose -f ../../docker-compose.yml down",
    "search:reindex": "tsx ../../scripts/reindex-meilisearch.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1013.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.9.0",
    "@shop/design-tokens": "*",
    "@shop/ui": "*",
    "@smithy/node-http-handler": "^4.5.0",
    "@upstash/redis": "^1.38.0",
    "@white-shop/db": "*",
    "bcryptjs": "^2.4.3",
    "browser-image-compression": "^2.0.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.555.0",
    "meilisearch": "^0.38.0",
    "next": "^16.2.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.66.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/browser-image-compression": "^1.0.1",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.0",
    "dotenv": "^16.3.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
