{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@shop/ui#build": {
      "outputs": []
    },
    "@shop/design-tokens#build": {
      "outputs": []
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "lint": {}
  }
}
