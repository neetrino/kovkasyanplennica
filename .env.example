# =============================================================================
# Kovkasyan Plennica — environment variables template
# =============================================================================
# Copy to repo root:
#   cp .env.example .env
# Next.js also reads: env/.env and env/.env.local (see apps/web/next.config.js)
# Never commit real secrets. .env is gitignored.
# =============================================================================

# --- Database (required) ---
# Neon Postgres connection string (global/main branch).
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require

# --- Auth (required) ---
# Min 32 chars. Used for JWT sign/verify (login, register, admin).
JWT_SECRET=change-me-to-a-random-secret-at-least-32-characters
# AUTH_SECRET=optional-alias-for-jwt-secret

# --- App URL (recommended) ---
# Public site URL for SSR, metadata, and absolute links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Leave empty when API routes run on the same Next.js app (default).
# NEXT_PUBLIC_API_URL=

# --- Cloudflare R2 — file storage (required for uploads/images) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public CDN base URL (no trailing slash), e.g. https://pub-xxx.r2.dev
R2_PUBLIC_URL=
# Browser-visible R2 base for /assets/... paths (often same as R2_PUBLIC_URL).
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=
# Optional prefix for bulk upload script (apps/web/scripts/upload-public-assets-to-r2.ts).
# R2_UPLOAD_PREFIX=

# --- Redis / cache (optional) ---
# Local Docker: npm run redis:up  →  redis://localhost:6379
REDIS_URL=redis://localhost:6379
# Upstash alternatives (REST API used by upstash-config; URL used by ioredis):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# UPSTASH_REDIS_URL=

# --- Meilisearch — product search (optional) ---
# Defaults to http://localhost:7700 when unset.
MEILI_HOST=http://localhost:7700
# MEILISEARCH_HOST=http://localhost:7700
MEILI_MASTER_KEY=
# MEILISEARCH_API_KEY=

# --- Health / monitoring (optional) ---
# Header x-health-probe must match for uptime checks to skip DB.
# HEALTH_PROBE_SECRET=

# --- Scripts only (not needed for npm run dev) ---
# npm run create-admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=Admin123!
# ADMIN_PHONE=

# prisma db seed (packages/db/prisma/seed.cjs)
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=Admin123!

# npm run migrate:mongo-to-postgres
# MONGODB_URI=mongodb://localhost:27017/shop

# npm run test-api-routes (scripts/test-api-routes.js)
# APP_URL=http://localhost:3000
