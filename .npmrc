# Registry mirror — օգնում է 403 Forbidden / rate limit խնդիրների դեպքում.
# Եթե ցանկանաս օգտագործել պաշտոնական registry, փոխարինի՛ր ներքևի տողը:
# registry=https://registry.npmjs.org/
registry=https://registry.npmmirror.com

# Vercel deploy: npmmirror-ը build ժամանակ ERR_INVALID_THIS է տալիս.
# Vercel Dashboard → Project → Settings → Environment Variables ավելացրու՛:
#   NPM_CONFIG_REGISTRY = https://registry.npmjs.org/
# (Environment: Production, Preview) — ապա redeploy.
